# 复制为 .env 后修改（勿提交 .env）
# cp .env.example .env

# 镜像名与标签
API_IMAGE_NAME=mutilmodel-api
NGINX_IMAGE_NAME=mutilmodel-web
IMAGE_TAG=latest

# 对外唯一端口：nginx 映射 宿主机:容器(80)
APP_PORT=8888

# 必填：DashScope API Key
DASHSCOPE_API_KEY=sk-your-key-here

# Redis
REDIS_PASSWORD=123456
# ECS 无法访问 Docker Hub 时：
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine

# 可选
# AGENTSCOPE_SESSION_KEY_PREFIX=agentscope:multimodal-demo:
# JAVA_TOOL_OPTIONS=-Ddashscope.vision-enable-thinking=false
