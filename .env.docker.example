# 复制为 .env.docker 后用于 docker build（已加入 .gitignore）
# cp .env.docker.example .env.docker

# 打给阿里云 ECS（x86）务必 amd64
BUILD_PLATFORM=linux/amd64
API_IMAGE_NAME=mutilmodel-api
NGINX_IMAGE_NAME=mutilmodel-web

# 方式 1：在 Dockerfile 中直接指定国内代理的基础镜像（不依赖 Docker Hub）
USE_CN_MIRROR=1

# DaoCloud 公共代理（library/ 前缀对应 Docker Hub 官方镜像）
NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
MAVEN_IMAGE=docker.m.daocloud.io/library/maven:3.9-eclipse-temurin-17
JRE_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:17-jre-jammy

# npm / Maven 加速（可选）
NPM_REGISTRY=https://registry.npmmirror.com
MAVEN_MIRROR=https://maven.aliyun.com/repository/public

# 方式 2：仅配置 Docker 守护进程镜像加速时，可注释 USE_CN_MIRROR，使用默认 node/maven 镜像名
