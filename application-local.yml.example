# 复制为 application-local.yml（已在 .gitignore），按需覆盖。
dashscope:
  api-key: "在此填写 DashScope API Key"
  vision-enable-thinking: false

# AgentScope 会话：默认 redis；无 Redis 时可改为 file
# agentscope:
#   session:
#     store: file

spring:
  data:
    redis:
      host: localhost
      port: 6379
      # 若本地 Redis 启用了 requirepass，取消下一行注释：
      # password: your-redis-password
